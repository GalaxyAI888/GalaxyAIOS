# 使用 NVIDIA CUDA 12.8.0 运行时基础镜像
FROM nvidia/cuda:12.8.0-runtime-ubuntu24.04

# 避免交互式配置提示
ENV DEBIAN_FRONTEND=noninteractive \
    LC_ALL=C.UTF-8 \
    LANG=C.UTF-8 \
    UV_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple \
    HF_ENDPOINT=https://hf-mirror.com \
    PATH="/root/.local/bin:/workspace/.venv/bin:$PATH"

# 更换阿里云 apt 源并安装依赖
RUN sed -i 's|http://archive.ubuntu.com/ubuntu/|https://mirrors.aliyun.com/ubuntu/|g' /etc/apt/sources.list.d/ubuntu.sources && \
    sed -i 's|http://security.ubuntu.com/ubuntu/|https://mirrors.aliyun.com/ubuntu/|g' /etc/apt/sources.list.d/ubuntu.sources && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        wget \
        git \
        && rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/* \
        && apt-get clean

# 安装 uv
RUN wget -qO- https://astral.sh/uv/install.sh | sh

# 创建工作目录
WORKDIR /workspace

# 创建虚拟环境并安装依赖（合并为一个 RUN 减少层数）
RUN uv venv /workspace/.venv --python 3.10 && \
    . /workspace/.venv/bin/activate && \
    # 安装兼容的 setuptools 和构建工具
    uv pip install "setuptools==69.5.1" "wheel==0.43.0" "packaging==23.2" && \
    uv pip install openai-whisper==20240930 --no-build-isolation && \
    uv pip install vox-box && \
    uv pip install ttsfrd && \
    uv pip install "ruamel.yaml==0.18.6" --link-mode=copy && \
    # 清理缓存减小镜像体积
    uv cache prune && \
    rm -rf /root/.cache/pip/*

# 暴露 vox-box-stt 服务端口
EXPOSE 7861

# 健康检查（检查 API 是否响应）
HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=3 \
    CMD curl -f http://127.0.0.1:7861/health || exit 1

# 设置入口点（使用 vox-box start）
ENTRYPOINT ["/workspace/.venv/bin/vox-box", "start"]

# 默认参数（可通过 docker run 覆盖）
CMD ["--host", "0.0.0.0", \
     "--port", "7861", \
     "--model", "/models/gpustack/faster-whisper-large-v3", \
     "--data-dir", "/models", \
     "--device", "cuda:0"]
